{
  "keybindings": {
    // ── 首页 ──
    "Home": {
      "<q>": "Quit",
      "<Ctrl-d>": "Quit",
      "<Ctrl-c>": "Quit",
      "<Ctrl-z>": "Suspend",
      "<Enter>": "Connect",        // 连接选中账户
      "<c>": "Compose",            // 快速写邮件（需已连接）
    },

    // ── 文件夹列表 ──
    "FolderList": {
      "<q>": "Quit",
      "<Esc>": "Back",
      "<j>": "NextMail",           // 向下
      "<k>": "PrevMail",           // 向上
      "<Enter>": "LoadMails",      // 进入选中文件夹
      "<R>": "RefreshFolders",     // 刷新
    },

    // ── 邮件列表 ──
    "MailList": {
      "<q>": "Quit",
      "<Esc>": "Back",
      "<j>": "NextMail",
      "<k>": "PrevMail",
      "<Enter>": "ViewMail",       // 查看选中邮件
      "<c>": "Compose",            // 新建邮件
      "<r>": "Reply",              // 回复
      "<a>": "ReplyAll",           // 回复全部
      "<f>": "Forward",            // 转发
      "<d>": "DeleteMail",         // 删除
      "<*>": "ToggleFlag",         // 星标
      "<M>": "LoadMoreMails",      // 加载更多
    },

    // ── 邮件阅读 ──
    "MailView": {
      "<q>": "Quit",
      "<Esc>": "Back",
      "<j>": "NextMail",
      "<k>": "PrevMail",
      "<r>": "Reply",
      "<a>": "ReplyAll",
      "<f>": "Forward",
      "<d>": "DeleteMail",
      "<*>": "ToggleFlag",
      "<h>": "ShowHtml",           // HTML 视图
      "<t>": "ShowText",           // 纯文本视图
    },
    
    // ── 写邮件 ──
    "Compose": {
      "<q>": "Quit",
      "<Esc>": "CancelCompose",
      "<Ctrl-s>": "Send",          // 发送
      "<Tab>": "Help",             // 切换输入框（暂用）
    },
  }
}
